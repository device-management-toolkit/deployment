# Common
# MPS_COMMON_NAME is auto-detected on `make up` to the host's primary LAN IP
# (e.g. 192.168.x.x) so that AMT devices can reach this host over CIRA and the
# TLS certs match. Set explicitly if you have a DNS name or want a different IP.
MPS_COMMON_NAME=
MPSPORT=4433

# Blank password fields below are auto-filled by `make up` (openssl rand).
# Set MPS_COMMON_NAME above; leave the rest blank for dev.

# Console
APP_ENCRYPTION_KEY=
LOG_LEVEL=info
HTTP_PORT=8181

# Console Auth
AUTH_DISABLED=false
AUTH_JWT_KEY=
AUTH_JWT_EXPIRATION=24h
# Simple mode (default `make up`): console's built-in login
AUTH_ISSUER=console
AUTH_ADMIN_USERNAME=standalone
AUTH_ADMIN_PASSWORD=
# Keycloak mode (`make up-keycloak`): OIDC. AUTH_ISSUER/AUTH_CLIENT_ID are set by
# docker-compose.keycloak.yml; these two are still needed for the realm import.
KEYCLOAK_ADMIN_PASSWORD=
# Login password for the `standalone` user in the console realm (the app login)
CONSOLE_USER_PASSWORD=

# RPS
RPSWEBPORT=8081
RPSWEBSOCKETPORT=8080
RPS_LOG_LEVEL=info
RPS_DELAY_TIMER=12

# MPS Router
PORT=8003
MPSWEBPORT=8181

# Postgres
POSTGRES_USER=postgresadmin
POSTGRES_PASSWORD=

# Vault
SECRETS_PATH=secret/data/
VAULT_ADDRESS=http://vault:8200
VAULT_TOKEN=

# Consul (disabled by default; RPS env vars still required)
CONSUL_ENABLED=false
CONSUL_HOST=
CONSUL_PORT=

# Tenant header injected by Kong (request-transformer) into x-tenant-id on /api routes.
# Leave blank to disable tenant header injection.
# In a multi-tenant deployment set this to the tenant identifier for this deployment instance.
# Example: KONG_TENANT_HEADER_VALUE=acme-corp
KONG_TENANT_HEADER_VALUE=
